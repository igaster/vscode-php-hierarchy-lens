# Copy this file to `.env` and fill in your tokens.
# `.env` is gitignored — never commit real tokens.

# VS Code Marketplace — Azure DevOps Personal Access Token
# (dev.azure.com → User Settings → Personal Access Tokens → scope: Marketplace = Manage)
VSCE_PAT=

# Open VSX — access token (open-vsx.org → Settings → Access Tokens)
OVSX_PAT=
